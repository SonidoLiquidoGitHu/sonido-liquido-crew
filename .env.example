# ===========================================
# SONIDO LIQUIDO CREW - ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env.local and fill in your values
# Do NOT commit .env.local to version control

# ===========================================
# REQUIRED - Core Application
# ===========================================

# NextAuth configuration
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# Database
DATABASE_URL=file:./data/sonido-liquido.db

# ===========================================
# REQUIRED - Spotify API
# ===========================================
# Get credentials at: https://developer.spotify.com/dashboard

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ===========================================
# REQUIRED - YouTube Data API
# ===========================================
# Get credentials at: https://console.cloud.google.com/apis

YOUTUBE_API_KEY=

# ===========================================
# REQUIRED - Dropbox API
# ===========================================
# Get credentials at: https://www.dropbox.com/developers/apps

DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_ACCESS_TOKEN=
DROPBOX_REFRESH_TOKEN=

# ===========================================
# OPTIONAL - Admin Authentication
# ===========================================
# Default admin credentials for initial setup
# Change these immediately in production

ADMIN_EMAIL=admin@sonidoliquido.com
ADMIN_PASSWORD=changeme123

# ===========================================
# OPTIONAL - Stripe (E-commerce)
# ===========================================
# Get credentials at: https://dashboard.stripe.com/apikeys
# Leave empty to disable e-commerce features

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ===========================================
# OPTIONAL - Mailchimp (Email Marketing)
# ===========================================
# Get credentials at: https://admin.mailchimp.com/account/api/
# Leave empty to disable Mailchimp integration

MAILCHIMP_API_KEY=
MAILCHIMP_SERVER_PREFIX=
MAILCHIMP_AUDIENCE_ID=

# ===========================================
# OPTIONAL - Site Configuration
# ===========================================

# Site URL for production
NEXT_PUBLIC_SITE_URL=https://sonidoliquido.com

# Contact information
NEXT_PUBLIC_CONTACT_EMAIL=prensasonidoliquido@gmail.com
NEXT_PUBLIC_CONTACT_PHONE=5528011881

# Social media links
NEXT_PUBLIC_SPOTIFY_URL=https://open.spotify.com/playlist/5qHTKCZIwi3GM3mhPq45Ab
NEXT_PUBLIC_YOUTUBE_URL=https://www.youtube.com/@sonidoliquidocrew
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/sonidoliquido/
NEXT_PUBLIC_FACEBOOK_URL=https://www.facebook.com/sonidoliquidocrew/

# ===========================================
# OPTIONAL - Sync Configuration
# ===========================================

# Sync intervals in minutes (default: 60)
SYNC_INTERVAL_SPOTIFY=60
SYNC_INTERVAL_YOUTUBE=120
SYNC_INTERVAL_DROPBOX=180

# ===========================================
# OPTIONAL - Push Notifications (VAPID)
# ===========================================
# Generate VAPID keys with: npx web-push generate-vapid-keys

NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:prensasonidoliquido@gmail.com

# ===========================================
# OPTIONAL - Feature Flags
# ===========================================

# Enable/disable features
FEATURE_ECOMMERCE=false
FEATURE_MAILCHIMP=false
FEATURE_DOWNLOAD_GATES=true
FEATURE_BEATS_GALLERY=true
FEATURE_PUSH_NOTIFICATIONS=true
FEATURE_AB_TESTING=true
